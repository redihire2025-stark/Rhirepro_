# Copy this file to .env and fill in the values
# Get these from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── EmailJS (for sending OTP via email) ──────────────────────────────────────
# Sign up at https://emailjs.com → create a service → create a template → copy keys below.
# Template variables needed: to_email, to_name, otp_code, expiry_minutes
# Leave blank to keep dev mode (OTP shown on screen instead of emailed).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
